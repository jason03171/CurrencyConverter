# Exchange Rate API Configuration
# Uncomment and configure as needed

# API Endpoint for fetching exchange rates
# Options: 
#   - https://api.exchangerate-api.com/v4/latest (Free, 1500 req/month)
#   - https://open.er-api.com/v6/latest (Free alternative)
# VITE_EXCHANGE_RATE_API=https://api.exchangerate-api.com/v4/latest

# Cache expiry time in hours
# How long to keep exchange rates in localStorage before fetching fresh data
# VITE_CACHE_EXPIRY_HOURS=1

# Optional: API Key (only needed for premium tiers or rate limit increases)
# VITE_EXCHANGE_RATE_API_KEY=your_api_key_here
